{
  "name": "@framekit/jobs",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": {
        "types": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test:integration": "vitest run --root ../.. packages/jobs/src/index.integration.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@framekit/core": "workspace:*",
    "@framekit/runtime": "workspace:*",
    "bullmq": "^5.79.2"
  },
  "description": "Framekit job queue and outbox helpers.",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "keywords": [
    "framekit",
    "typescript",
    "meta-framework",
    "jobs"
  ],
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/WilliamCorotan/FrameKit.git",
    "directory": "packages/jobs"
  },
  "bugs": {
    "url": "https://github.com/WilliamCorotan/FrameKit/issues"
  },
  "homepage": "https://github.com/WilliamCorotan/FrameKit#readme"
}
