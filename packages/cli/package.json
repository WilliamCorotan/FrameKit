{
  "name": "@framekit/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "framekit": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "framekit": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@framekit/core": "workspace:*",
    "@framekit/runtime": "workspace:*",
    "@framekit/sdk": "workspace:*",
    "tsx": "^4.22.4"
  }
}
