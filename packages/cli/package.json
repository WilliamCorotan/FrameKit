{
  "name": "@framekit/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "framekit": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": {
        "types": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "framekit": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@framekit/core": "workspace:*",
    "@framekit/runtime": "workspace:*",
    "@framekit/sdk": "workspace:*",
    "tsx": "^4.22.4"
  },
  "description": "Framekit project and code generation CLI.",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "keywords": [
    "framekit",
    "typescript",
    "meta-framework",
    "cli"
  ],
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/WilliamCorotan/FrameKit.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/WilliamCorotan/FrameKit/issues"
  },
  "homepage": "https://github.com/WilliamCorotan/FrameKit#readme"
}
