{
  "name": "@framekit/desk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:fullstack": "vite build --mode fullstack && pnpm --filter @framekit/example-crm... build",
