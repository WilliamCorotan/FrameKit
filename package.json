{
  "name": "framekit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "description": "A Nitro-powered TypeScript meta-framework inspired by Frappe.",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm --filter @framekit/example-crm dev",
    "dev:desk": "pnpm --filter @framekit/desk dev",
    "lint": "tsc -p tsconfig.check.json --noEmit",
    "release:candidate": "node scripts/release-candidate.mjs",
    "release:candidate:check": "node scripts/release-candidate.mjs --check",
    "release:prepare": "node scripts/prepare-release.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "audit:dependencies": "pnpm audit --audit-level high",
    "test:desk:browser": "pnpm --filter @framekit/desk test:browser",
    "test:desk:fullstack": "pnpm --filter @framekit/desk test:browser:fullstack",
    "test:services": "pnpm --filter @framekit/db test:integration && pnpm --filter @framekit/jobs test:integration",
    "verify:package-exports": "node scripts/verify-package-exports.mjs",
    "verify:standalone": "node scripts/verify-standalone.mjs",
    "smoke:crm:built": "pnpm --filter @framekit/example-crm smoke:built",
    "test:smoke:crm:built": "pnpm --filter @framekit/example-crm test:smoke-built",
    "typecheck": "pnpm -r --if-present typecheck",
    "audit:all": "pnpm lint && pnpm typecheck && pnpm test:coverage && pnpm build"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.1.10",
    "typescript": "^7.0.2",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
